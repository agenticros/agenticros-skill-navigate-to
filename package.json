{
  "name": "@agenticros-skills/navigate-to",
  "version": "0.1.0",
  "type": "module",
  "description": "External ROS-node skill: navigate to a pose via Nav2 NavigateToPose.",
  "keywords": [
    "agenticros",
    "nav2",
    "navigation",
    "ros2"
  ],
  "homepage": "https://github.com/agenticros/agenticros-skill-navigate-to#readme",
  "bugs": {
    "url": "https://github.com/agenticros/agenticros-skill-navigate-to/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agenticros/agenticros-skill-navigate-to.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "agenticros": {
    "id": "navigate-to",
    "displayName": "Navigate To",
    "description": "Send a Nav2 NavigateToPose goal. Requires Nav2 running on the robot; AgenticROS dispatches the action over the configured transport.",
    "categories": [
      "navigation"
    ],
    "capabilities": [
      {
        "id": "navigate_to",
        "verb": "navigate",
        "description": "Navigate the robot base to a map pose via Nav2.",
        "inputs": {
          "x": {
            "type": "number",
            "description": "Goal x in meters (map frame)."
          },
          "y": {
            "type": "number",
            "description": "Goal y in meters (map frame)."
          },
          "yaw": {
            "type": "number",
            "description": "Goal yaw in radians.",
            "optional": true
          },
          "frame_id": {
            "type": "string",
            "description": "Pose frame_id (default map).",
            "optional": true
          }
        },
        "outputs": {
          "success": {
            "type": "boolean",
            "description": "Whether the action reported success."
          }
        },
        "interruptible": true,
        "blocks_base": true,
        "implementation": {
          "kind": "external_ros_node",
          "package": "nav2_bringup",
          "launch": "navigation_launch.py",
          "action": "navigate_to_pose",
          "msg_type": "nav2_msgs/action/NavigateToPose"
        }
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "typescript": "^5.7.0"
  },
  "author": "AgenticROS",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  }
}
